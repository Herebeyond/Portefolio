{% extends 'base.html.twig' %}

{% block title %}Compétences — Portfolio {{ portfolio.identity.name }}{% endblock %}
{% block description %}Technologies, langages, frameworks et certifications maîtrisés par {{ portfolio.identity.name }}.{% endblock %}

{# Macro : barre de progression sur 5 #}
{% macro level_bar(level, max) %}
    {% set max = max|default(5) %}
    {% set percent = (level / max * 100)|round %}
    <div class="skill-bar" role="img" aria-label="Niveau : {{ level }} sur {{ max }}">
        <span class="skill-bar-fill" style="width: {{ percent }}%;"></span>
    </div>
{% endmacro %}

{% import _self as ui %}

{% block body %}
<section class="page-header">
    <div class="container">
        <h1 class="page-title">Mes <span class="highlight">compétences</span></h1>
        <p class="page-subtitle">Les technologies et outils que je maîtrise</p>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">Mes <span class="highlight">certifications</span></h2>
        <div class="certifications-grid">
            {% for cert in portfolio.certifications %}
                <div class="certification-card">
                    <div class="certification-icon" aria-hidden="true">{{ cert.icon }}</div>
                    <h3>{{ cert.name }}</h3>
                    <p class="certification-date">{{ cert.subtitle }}</p>
                    <p>{{ cert.description }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="section-title">Langages de <span class="highlight">programmation</span></h2>
        <div class="skills-grid">
            {% for s in portfolio.languages %}
                <div class="skill-card">
                    <div class="skill-icon" style="background:{{ s.bg }};color:{{ s.color }};">{{ s.label }}</div>
                    <h3>{{ s.name }}</h3>
                    {{ ui.level_bar(s.level) }}
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">Frameworks &amp; <span class="highlight">Outils</span></h2>
        <div class="skills-grid">
            {% for s in portfolio.tools %}
                <div class="skill-card">
                    <div class="skill-icon" style="background:{{ s.bg }};color:{{ s.color }};">{{ s.label }}</div>
                    <h3>{{ s.name }}</h3>
                    {{ ui.level_bar(s.level) }}
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="section-title">Compétences <span class="highlight">bureautiques</span></h2>
        <div class="skills-grid">
            {% for s in portfolio.officeTools %}
                <div class="skill-card">
                    <div class="skill-icon" style="background:{{ s.bg }};color:{{ s.color }};">{{ s.label }}</div>
                    <h3>{{ s.name }}</h3>
                    {{ ui.level_bar(s.level) }}
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">Compétences <span class="highlight">transversales</span></h2>
        <div class="skills-grid">
            {% for s in portfolio.softSkills %}
                <div class="skill-card">
                    <h3>{{ s.name }}</h3>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
