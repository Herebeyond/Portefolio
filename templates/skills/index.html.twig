{% extends 'base.html.twig' %}

{% block title %}Compétences — Portfolio{% endblock %}

{% block body %}
<section class="page-header">
    <div class="container">
        <h1 class="page-title">Mes <span class="highlight">compétences</span></h1>
        <p class="page-subtitle">Les technologies et outils que je maîtrise</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="section-title">Langages de <span class="highlight">programmation</span></h2>
        <div class="skills-grid">
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/6C63FF/ffffff?text=PHP" alt="PHP">
                </div>
                <h3>PHP</h3>
                <div class="skill-stars">★★★★☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/F7DF1E/000000?text=JS" alt="JavaScript">
                </div>
                <h3>JavaScript</h3>
                <div class="skill-stars">★★★☆☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/3776AB/ffffff?text=PY" alt="Python">
                </div>
                <h3>Python</h3>
                <div class="skill-stars">★★★☆☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/E34F26/ffffff?text=HTML" alt="HTML/CSS">
                </div>
                <h3>HTML / CSS</h3>
                <div class="skill-stars">★★★★☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/336791/ffffff?text=SQL" alt="SQL">
                </div>
                <h3>SQL</h3>
                <div class="skill-stars">★★★★☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/512BD4/ffffff?text=C%23" alt="C#">
                </div>
                <h3>C#</h3>
                <div class="skill-stars">★★★☆☆</div>
            </div>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">Frameworks & <span class="highlight">Outils</span></h2>
        <div class="skills-grid">
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/000000/ffffff?text=SF" alt="Symfony">
                </div>
                <h3>Symfony</h3>
                <div class="skill-stars">★★★☆☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/F05032/ffffff?text=GIT" alt="Git">
                </div>
                <h3>Git</h3>
                <div class="skill-stars">★★★★☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/2496ED/ffffff?text=DCK" alt="Docker">
                </div>
                <h3>Docker</h3>
                <div class="skill-stars">★★☆☆☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/4479A1/ffffff?text=MYS" alt="MySQL">
                </div>
                <h3>MySQL</h3>
                <div class="skill-stars">★★★★☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/007ACC/ffffff?text=VS" alt="VS Code">
                </div>
                <h3>VS Code</h3>
                <div class="skill-stars">★★★★☆</div>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <img src="https://via.placeholder.com/60x60/0078D6/ffffff?text=WIN" alt="Windows/Linux">
                </div>
                <h3>Windows / Linux</h3>
                <div class="skill-stars">★★★☆☆</div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
