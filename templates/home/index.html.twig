{% extends 'base.html.twig' %}

{% set p = portfolio.identity %}

{% block title %}Présentation — Portfolio {{ p.name }}{% endblock %}
{% block description %}{{ p.description|striptags|trim }}{% endblock %}

{% block body %}
<section class="hero">
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <p class="hero-greeting">Bonjour, je suis</p>
                <h1 class="hero-name">{{ p.name }}</h1>
                <h2 class="hero-title">Étudiant en <span class="highlight">{{ p.short_role }}</span></h2>
                <p class="hero-description">{{ p.description }}</p>
                <div class="hero-buttons">
                    <a href="{{ path('app_projects') }}" class="btn btn-primary">Voir mes projets</a>
                    <a href="#a-propos" class="btn btn-outline">En savoir plus</a>
                </div>
                <div class="hero-social">
                    <a href="{{ p.github }}" class="social-link" aria-label="Profil GitHub de {{ p.name }}" target="_blank" rel="noopener">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                    <a href="{{ p.linkedin }}" class="social-link" aria-label="Profil LinkedIn de {{ p.name }}" target="_blank" rel="noopener">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                </div>
            </div>
            <div class="hero-image">
                <div class="hero-photo-wrapper">
                    <img src="{{ asset(p.photo) }}" alt="Portrait de {{ p.name }}" class="hero-photo" width="350" height="350">
                </div>
                <div class="hero-decoration" aria-hidden="true"></div>
            </div>
        </div>

        <a href="#a-propos" class="hero-scroll" aria-label="Faire défiler vers la section À propos">
            <span class="hero-scroll-text">Découvrir</span>
            <span class="hero-scroll-arrow" aria-hidden="true">↓</span>
        </a>
    </div>
</section>

<section class="section" id="a-propos">
    <div class="container">
        <h2 class="section-title">À propos <span class="highlight">de moi</span></h2>
        <div class="about-grid about-grid--compact">
            <div class="about-text-col">
                {% for paragraph in p.about %}
                    <p>{{ paragraph }}</p>
                {% endfor %}

                <div class="about-info">
                    <div class="info-item">
                        <span class="info-label">Formation :</span>
                        <span class="info-value">{{ p.short_role }} — {{ p.formation_year }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Établissement :</span>
                        <span class="info-value">{{ p.school }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Localisation :</span>
                        <span class="info-value">{{ p.location }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email :</span>
                        <span class="info-value">{{ p.email }}</span>
                    </div>
                </div>

                <div class="about-cta">
                    <a href="{{ path('app_education') }}" class="btn btn-outline btn-sm">Mon parcours</a>
                    <a href="{{ path('app_skills') }}" class="btn btn-outline btn-sm">Mes compétences</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-alt" id="documents">
    <div class="container">
        <h2 class="section-title">Mes <span class="highlight">documents</span></h2>
        <div class="documents-grid">
            <a href="{{ asset('documents/CV_Benjamin_BAILLARD.pdf') }}" class="btn btn-primary" target="_blank" rel="noopener">CV (PDF)</a>
            <a href="{{ asset('documents/Fiche_Bilan_stage_CHU.pdf') }}" class="btn btn-outline" target="_blank" rel="noopener">Bilan de stage — CHU</a>
            <button type="button" class="btn btn-outline btn-disabled" disabled aria-disabled="true">Bilan de stage — Rectorat (à venir)</button>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">Mes <span class="highlight">centres d'intérêt</span></h2>
        <div class="interests-grid">
            {% for interest in p.interests %}
                <div class="interest-card">
                    <div class="interest-icon" aria-hidden="true">{{ interest.icon }}</div>
                    <h3>{{ interest.title }}</h3>
                    <p>{{ interest.text }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
