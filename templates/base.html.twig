<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Portfolio — BTS SIO SLAM{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>💻</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <nav class="navbar">
            <div class="nav-container">
                <a href="{{ path('app_home') }}" class="nav-logo">
                    <span class="logo-bracket">&lt;</span>Portfolio<span class="logo-bracket"> /&gt;</span>
                </a>
                <button class="nav-toggle" id="navToggle" aria-label="Menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-links" id="navLinks">
                    <li><a href="{{ path('app_home') }}" class="{% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">Accueil</a></li>
                    <li><a href="{{ path('app_about') }}" class="{% if app.request.attributes.get('_route') == 'app_about' %}active{% endif %}">À propos</a></li>
                    <li><a href="{{ path('app_skills') }}" class="{% if app.request.attributes.get('_route') == 'app_skills' %}active{% endif %}">Compétences</a></li>
                    <li><a href="{{ path('app_projects') }}" class="{% if app.request.attributes.get('_route') == 'app_projects' %}active{% endif %}">Projets</a></li>
                    <li><a href="{{ path('app_education') }}" class="{% if app.request.attributes.get('_route') == 'app_education' %}active{% endif %}">Formation</a></li>
                    <li><a href="{{ path('app_contact') }}" class="{% if app.request.attributes.get('_route') == 'app_contact' %}active{% endif %}">Contact</a></li>
                </ul>
            </div>
        </nav>

        <main class="main-content">
            {% block body %}{% endblock %}
        </main>

        <footer class="footer">
            <div class="container">
                <div class="footer-content">
                    <div class="footer-left">
                        <span class="footer-logo"><span class="logo-bracket">&lt;</span>Portfolio<span class="logo-bracket"> /&gt;</span></span>
                        <p>Étudiant en BTS SIO option SLAM</p>
                        <p>Lycée Beaupeyrat — Limoges</p>
                    </div>
                    <div class="footer-center">
                        <h4>Navigation</h4>
                        <ul>
                            <li><a href="{{ path('app_home') }}">Accueil</a></li>
                            <li><a href="{{ path('app_about') }}">À propos</a></li>
                            <li><a href="{{ path('app_skills') }}">Compétences</a></li>
                            <li><a href="{{ path('app_projects') }}">Projets</a></li>
                            <li><a href="{{ path('app_education') }}">Formation</a></li>
                            <li><a href="{{ path('app_contact') }}">Contact</a></li>
                        </ul>
                    </div>
                    <div class="footer-right">
                        <h4>Liens</h4>
                        <ul>
                            <li><a href="#" target="_blank" rel="noopener">GitHub</a></li>
                            <li><a href="#" target="_blank" rel="noopener">LinkedIn</a></li>
                            <li><a href="mailto:votre.email@example.com">Email</a></li>
                        </ul>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>&copy; {{ "now"|date("Y") }} — Portfolio BTS SIO SLAM. Tous droits réservés.</p>
                </div>
            </div>
        </footer>
    </body>
</html>
