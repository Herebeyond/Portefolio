{% extends 'base.html.twig' %}

{% block title %}À propos — Portfolio{% endblock %}

{% block body %}
<section class="page-header">
    <div class="container">
        <h1 class="page-title">À propos <span class="highlight">de moi</span></h1>
        <p class="page-subtitle">Apprenez-en plus sur mon parcours et mes passions</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="about-grid">
            <div class="about-image-col">
                <div class="about-photo-wrapper">
                    <img src="{{ asset('images/photo.png') }}" alt="Benjamin Baillard" class="about-photo">
                </div>
            </div>
            <div class="about-text-col">
                <h2>Qui suis-je ?</h2>
                <p>
                    Étudiant en deuxième année de BTS Services Informatiques aux Organisations, option SLAM, je suis attiré principalement par le développement de logiciels informatiques.
                </p>
                <p>
                    Ayant acquis une base solide en programmation et gestion de bases de données, je souhaite approfondir mes compétences techniques tout en mettant en pratique mes connaissances lors de stages en entreprise.
                </p>
                <p>
                    Doté d'une bonne capacité d'adaptation et d'une forte motivation, je souhaite évoluer dans un environnement stimulant et collaboratif. Adaptable, créatif, avec un esprit critique et bon communicant.
                </p>

                <div class="about-info">
                    <div class="info-item">
                        <span class="info-label">Nom :</span>
                        <span class="info-value">Benjamin Baillard</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Formation :</span>
                        <span class="info-value">BTS SIO SLAM — 2ème année</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Établissement :</span>
                        <span class="info-value">Lycée Beaupeyrat</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Localisation :</span>
                        <span class="info-value">Limoges, France</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email :</span>
                        <span class="info-value">baillard.bjm1@orange.fr</span>
                    </div>
                </div>

                <a href="{{ path('app_contact') }}" class="btn btn-primary">Me contacter</a>
            </div>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">Mes <span class="highlight">centres d'intérêt</span></h2>
        <div class="interests-grid">
            <div class="interest-card">
                <div class="interest-icon">📚</div>
                <h3>Lecture</h3>
                <p>Passionné de littérature fantastique et de science-fiction.</p>
            </div>
            <div class="interest-card">
                <div class="interest-icon">🎮</div>
                <h3>Jeux vidéo</h3>
                <p>Amateur de RPG et jeux de gestion.</p>
            </div>
            <div class="interest-card">
                <div class="interest-icon">✍️</div>
                <h3>Écriture</h3>
                <p>Écriture de récits et création d'univers narratifs.</p>
            </div>
            <div class="interest-card">
                <div class="interest-icon">🎵</div>
                <h3>Musique</h3>
                <p>Principalement du métal, mais j'écoute un peu de tout.</p>
            </div>
        </div>
    </div>
</section>
{% endblock %}
