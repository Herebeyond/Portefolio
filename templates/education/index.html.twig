{% extends 'base.html.twig' %}

{% block title %}Formation — Portfolio{% endblock %}

{% block body %}
<section class="page-header">
    <div class="container">
        <h1 class="page-title">Ma <span class="highlight">formation</span></h1>
        <p class="page-subtitle">Mon parcours scolaire et mes certifications</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="timeline">

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-date">2024 — 2026</div>
                    <h3>BTS SIO — Option SLAM</h3>
                    <h4>Lycée Beaupeyrat — Limoges</h4>
                    <p>
                        Solutions Logicielles et Applications Métiers. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Formation axée sur le développement d'applications, les bases de données, la cybersécurité et la gestion de projets informatiques.
                    </p>
                    <div class="timeline-tags">
                        <span class="tag">PHP</span>
                        <span class="tag">SQL</span>
                        <span class="tag">C#</span>
                        <span class="tag">Réseaux</span>
                        <span class="tag">Cybersécurité</span>
                    </div>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-date">2023 — 2024</div>
                    <h3>Licence Informatique — 1ère année</h3>
                    <h4>Université — Limoges</h4>
                    <p>
                        Première année de licence informatique. Approfondissement des bases en algorithmique, programmation et mathématiques pour l'informatique.
                    </p>
                    <div class="timeline-tags">
                        <span class="tag">Algorithmique</span>
                        <span class="tag">Programmation</span>
                    </div>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-date">2021 — 2023</div>
                    <h3>Classe préparatoire</h3>
                    <h4>3iL — Limoges</h4>
                    <p>
                        Classe préparatoire intégrée en école d'ingénieurs informatique. Introduction aux fondamentaux de l'informatique et des sciences.
                    </p>
                    <div class="timeline-tags">
                        <span class="tag">Informatique</span>
                        <span class="tag">Sciences</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">Certifications & <span class="highlight">Veille</span></h2>
        <div class="certifications-grid">
            <div class="certification-card">
                <div class="certification-icon">☁️</div>
                <h3>AWS</h3>
                <p class="certification-date">Amazon Web Services</p>
                <p>Certification cloud computing Amazon Web Services.</p>
            </div>
            <div class="certification-card">
                <div class="certification-icon">🔒</div>
                <h3>ANSSI</h3>
                <p class="certification-date">Cybersécurité</p>
                <p>Agence nationale de la sécurité des systèmes d'information.</p>
            </div>
            <div class="certification-card">
                <div class="certification-icon">🖥️</div>
                <h3>Pix — Avancé 1</h3>
                <p class="certification-date">Compétences numériques</p>
                <p>Certification Pix niveau Avancé 1 en compétences numériques.</p>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="section-title">Stages & <span class="highlight">Expériences</span></h2>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-date">Stage — BTS SIO</div>
                    <h3>Développeur logiciel — CHU de Limoges</h3>
                    <h4>Service informatique — Limoges</h4>
                    <p>
                        Stage d'apprentissage en tant que développeur logiciel au service informatique du CHU de Limoges. Développement et maintenance d'applications métiers.
                    </p>
                    <div class="timeline-tags">
                        <span class="tag">Développement</span>
                        <span class="tag">Logiciel</span>
                        <span class="tag">Santé</span>
                    </div>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-date">Stage — BTS SIO</div>
                    <h3>Développeur web — Rectorat de Limoges</h3>
                    <h4>Rectorat — Limoges</h4>
                    <p>
                        Stage d'apprentissage en tant que développeur web au Rectorat de Limoges. Participation au développement d'applications web internes.
                    </p>
                    <div class="timeline-tags">
                        <span class="tag">Web</span>
                        <span class="tag">PHP</span>
                    </div>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-date">Stage d'observation</div>
                    <h3>Machiniste — Opéra de Limoges</h3>
                    <h4>Opéra — Limoges</h4>
                    <p>
                        Stage d'observation en tant que machiniste à l'Opéra de Limoges. Découverte du monde du spectacle et des métiers techniques.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
