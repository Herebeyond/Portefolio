{% extends 'base.html.twig' %}

{% block title %}Formation — Portfolio {{ portfolio.identity.name }}{% endblock %}
{% block description %}Parcours scolaire et expériences professionnelles de {{ portfolio.identity.name }}.{% endblock %}

{% block body %}
<section class="page-header">
    <div class="container">
        <h1 class="page-title">Formation & <span class="highlight">Expériences</span></h1>
        <p class="page-subtitle">Mon parcours scolaire et professionnel</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="formation-columns">
            <div class="formation-col">
                <h2 class="col-title"><span aria-hidden="true">📚</span> Formation</h2>
                <div class="timeline">
                    {% for item in portfolio.formations %}
                        <div class="timeline-item">
                            <div class="timeline-dot">
                                <img src="{{ asset(item.logo) }}" alt="{{ item.alt }}" class="timeline-logo" loading="lazy" decoding="async" width="60" height="60">
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-date">{{ item.period }}</div>
                                <h3>{{ item.title }}</h3>
                                <h4>{{ item.place }}</h4>
                                <p>{{ item.description }}</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="formation-col">
                <h2 class="col-title"><span aria-hidden="true">💼</span> Stages &amp; Expériences</h2>
                <div class="timeline">
                    {% for item in portfolio.experiences %}
                        <div class="timeline-item">
                            <div class="timeline-dot">
                                <img src="{{ asset(item.logo) }}" alt="{{ item.alt }}" class="timeline-logo" loading="lazy" decoding="async" width="60" height="60">
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-date">{{ item.period }}</div>
                                <h3>{{ item.title }}</h3>
                                <p>{{ item.description }}</p>
                                {% if item.tags is defined %}
                                    <ul class="timeline-tags">
                                        {% for tag in item.tags %}
                                            <li class="tag">{{ tag }}</li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
