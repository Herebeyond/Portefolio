{% extends 'base.html.twig' %}

{% block title %}Projets — Portfolio {{ portfolio.identity.name }}{% endblock %}
{% block description %}Découvrez les projets réalisés par {{ portfolio.identity.name }} durant sa formation BTS SIO et en autonomie.{% endblock %}

{% block body %}
<section class="page-header">
    <div class="container">
        <h1 class="page-title">Mes <span class="highlight">projets</span></h1>
        <p class="page-subtitle">Découvrez les projets réalisés durant ma formation et en autonomie</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="projects-grid">
            {% for project in portfolio.projects %}
                <article class="project-card">
                    <div class="project-image">
                        <img src="{{ asset(project.image) }}" alt="{{ project.alt }}" loading="lazy" decoding="async">
                    </div>
                    <div class="project-info">
                        <span class="project-context">{{ project.context }}</span>
                        <h2>{{ project.title }}</h2>
                        <p>{{ project.description }}</p>
                        <ul class="project-tags">
                            {% for tag in project.tags %}
                                <li class="tag">{{ tag }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
